{
  "rewrites": [
    { "source": "/plantcare-api/(.*)", "destination": "https://plantcare-api-prod.polygonagro.com/plantcare-api/$1" },
    { "source": "/collector-api/(.*)", "destination": "https://collector-api-prod.polygonagro.com/collector-api/$1" },
    { "source": "/dash-api/(.*)", "destination": "https://dash-api-prod.polygonagro.com/dash-api/$1" },
    { "source": "/cc-api/(.*)", "destination": "https://cc-api-prod.polygonagro.com/cc-api/$1" },
    
    {
      "source": "/admin-api/agro-api/admin-api/(.*)",
      "destination": "https://admin-api-prod.polygonagro.com/admin-api/$1"
    },
    {
      "source": "/admin-api/(.*)",
      "destination": "https://admin-api-prod.polygonagro.com/admin-api/$1"
    },
    {
      "source": "/admin",
      "destination": "https://admin-panel-prod.polygonagro.com"
    },
    {
      "source": "/admin/(.*)",
      "destination": "https://admin-panel-prod.polygonagro.com/admin/$1"
    },
    {
      "source": "/cc",
      "destination": "https://cc-web-prod.polygonagro.com"
    },
    {
      "source": "/cc/(.*)",
      "destination": "https://cc-web-prod.polygonagro.com/cc/$1"
    },
    {
      "source": "/market/_next/static/(.*)",
      "destination": "https://market-prod.polygonagro.com/market/_next/static/$1"
    },
    {
      "source": "/market/(.*)",
      "destination": "https://market-prod.polygonagro.com/market/$1"
    }
  ],
  "headers": [
    {
      "source": "/admin-api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    }
  ]
}