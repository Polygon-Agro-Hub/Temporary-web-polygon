{
  "rewrites": [
    {
      "source": "/plantcare-api/(.*)",
      "destination": "https://plantcare-api-prod.polygonagro.com/$1"
    },
    {
      "source": "/collector-api/(.*)",
      "destination": "https://collector-api-prod.polygonagro.com/$1"
    },
    {
      "source": "/dash-api/(.*)",
      "destination": "https://dash-api-prod.polygonagro.com/$1"
    },
    {
      "source": "/cc-api/(.*)",
      "destination": "https://cc-api-prod.polygonagro.com/$1"
    },
    {
      "source": "/admin-api/path*",
      "destination": "https://admin-api-prod.polygonagro.com/:path*"
    },
    {
      "source": "/admin/:path*",
      "destination": "https://admin-panel-prod.polygonagro.com/:path*"
    },
    {
      "source": "/cc/:path*",
      "destination": "https://cc-web-prod.polygonagro.com/:path*"
    },
    {
      "source": "/market/_next/static/(.*)",
      "destination": "https://market-prod.polygonagro.com/market/_next/static/$1"
    },
    {
      "source": "/market/(.*)",
      "destination": "https://market-prod.polygonagro.com/market/$1"
    }
  ]
}